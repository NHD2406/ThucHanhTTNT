        "\"\"\"Bài 13\"\"\"\n",
        "def merge_arrays_with_sum(arr1, arr2):\n",
        "    result_array = []\n",
        "    len1 = len(arr1)\n",
        "    len2 = len(arr2)\n",
        "    min_len = min(len1, len2)\n",
        "    for i in range(min_len):\n",
        "        result_array.append(arr1[i] + arr2[i])\n",
        "    if len1 > min_len:\n",
        "        result_array.extend(arr1[min_len:])\n",
        "    elif len2 > min_len:\n",
        "        result_array.extend(arr2[min_len:])\n",
        "    return result_array\n",
        "arr_a = [3, 9, 1, 4]\n",
        "arr_b = [2, 7, 4, 3, 2, 8]\n",
        "merged_result = merge_arrays_with_sum(arr_a, arr_b)\n",
        "print(f\"Mảng a: {arr_a}\")\n",
        "print(f\"Mảng b: {arr_b}\")\n",
        "print(f\"Mảng kết quả: {merged_result}\")\n",
        "arr_x = [1, 2, 3, 4, 5]\n",
        "arr_y = [10, 20]\n",
        "merged_result_xy = merge_arrays_with_sum(arr_x, arr_y)\n",
        "print(f\"\\nMảng x: {arr_x}\")\n",
        "print(f\"Mảng y: {arr_y}\")\n",
        "print(f\"Mảng kết quả (x,y): {merged_result_xy}\")"
      ],
