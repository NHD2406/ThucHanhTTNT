      },
      "source": [
        "\"\"\"Bài 12\"\"\"\n",
        "total_sum = 0\n",
        "for number in range(1000):\n",
        "    if (number % 3 == 0) or (number % 5 == 0):\n",
        "        total_sum += number\n",
        "\n",
        "print(f\"Tổng các số từ 0 đến 999 là bội của 3 hoặc 5 là: {total_sum}\")"
      ],
